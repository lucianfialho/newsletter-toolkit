#!/usr/bin/env node
/**
 * build-voice-profile
 *
 * Analyzes the last N newsletters saved in CLAUDE_PLUGIN_DATA and generates
 * a compact voice profile that the humanizer skill uses to calibrate tone.
 *
 * Usage:
 *   build-voice-profile [N]     # N = number of newsletters to analyze (default: 5)
 *   build-voice-profile --force # recalculate even if profile is recent
 */

'use strict';

const fs = require('fs');
const path = require('path');

// Plugin data dir — set by Claude Code when the plugin runs
const DATA_DIR = process.env.CLAUDE_PLUGIN_DATA || path.join(process.env.HOME, '.claude', 'plugins', 'data', 'newsletter-toolkit');
const NEWSLETTERS_DIR = path.join(DATA_DIR, 'newsletters');
const PROFILE_FILE = path.join(DATA_DIR, 'voice-profile.json');

function readNewsletter(filepath) {
  const content = fs.readFileSync(filepath, 'utf8');
  // Strip frontmatter
  const match = content.match(/^---[\s\S]*?---\s*([\s\S]*)$/);
  return match ? match[1] : content;
}

function extractSentences(text) {
  const clean = text
    .replace(/^#+\s+.*$/gm, '')
    .replace(/^\s*[-*]\s+/gm, '')
    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
    .replace(/\*\*([^*]*)\*\*/g, '$1')
    .replace(/---/g, '')
    .replace(/\n{2,}/g, '\n')
    .trim();

  return clean
    .split(/(?<=[.!?])\s+/)
    .map(s => s.trim())
    .filter(s => s.length > 10);
}

function analyzeSentenceRhythm(sentences) {
  const lengths = sentences.map(s => s.split(/\s+/).length);
  if (lengths.length === 0) return { avg: 0, min: 0, max: 0, stddev: 0 };

  const avg = lengths.reduce((a, b) => a + b, 0) / lengths.length;
  const variance = lengths.reduce((sum, l) => sum + Math.pow(l - avg, 2), 0) / lengths.length;

  return {
    avg: Math.round(avg * 10) / 10,
    min: Math.min(...lengths),
    max: Math.max(...lengths),
    stddev: Math.round(Math.sqrt(variance) * 10) / 10,
    sampleSize: lengths.length
  };
}

function extractOpeningPatterns(texts) {
  return texts.map(text => {
    const lines = text.split('\n').filter(l => l.trim());
    const contentStart = lines.findIndex(l =>
      !l.startsWith('#') && l.length > 30
    );
    if (contentStart === -1) return null;
    return lines[contentStart].trim();
  }).filter(Boolean);
}

function extractTransitionPatterns(text) {
  const patterns = [];
  const lines = text.split('\n');

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    if (line === '---' && lines[i + 1]) {
      const next = (lines[i + 1] || '').trim();
      if (next && !next.startsWith('#') && next.length > 20) {
        patterns.push(next.substring(0, 80));
      }
    }
  }

  return patterns;
}

function extractEditorialPhrases(text) {
  const phrases = [];
  const editorialPatterns = [
    /merece\s+atenc[aã]o/gi,
    /vale\s+(?:ficar\s+de\s+olho|a\s+pena|checar|revisar)/gi,
    /quem\s+(?:opera|trabalha|usa|tem)/gi,
    /na\s+pr[aá]tica/gi,
    /o\s+que\s+muda/gi,
    /isso\s+(?:muda|significa|fecha|abre)/gi,
  ];

  editorialPatterns.forEach(pattern => {
    const matches = text.match(pattern);
    if (matches) {
      matches.forEach(m => phrases.push(m.toLowerCase()));
    }
  });

  return [...new Set(phrases)];
}

function extractWordsAvoided(sentences) {
  const aiWords = [
    'crucial', 'fundamental', 'essencial', 'cenário', 'panorama',
    'potencializar', 'alavancar', 'holístico', 'robusto', 'abrangente',
    'certamente', 'nesse contexto', 'nesse sentido', 'vale ressaltar',
    'cabe destacar', 'adicionalmente', 'revolucionário', 'inovador',
    'disruptivo', 'game-changer', 'ecossistema vibrante', 'jornada', 'marco'
  ];

  const allText = sentences.join(' ').toLowerCase();
  const avoided = aiWords.filter(w => !allText.includes(w));
  const usedFromAiList = aiWords.filter(w => allText.includes(w));

  return { avoided, usedFromAiList };
}

function extractFrequentWords(sentences) {
  const wordCount = {};
  const stopwords = new Set([
    'a', 'o', 'e', 'de', 'do', 'da', 'em', 'um', 'uma', 'que', 'para',
    'com', 'não', 'no', 'na', 'os', 'as', 'se', 'por', 'mais', 'é',
    'dos', 'das', 'ao', 'ou', 'isso', 'esse', 'essa', 'este', 'esta',
    'são', 'já', 'como', 'mas', 'sua', 'seu', 'tem', 'foi', 'ser',
    'pode', 'está', 'até', 'sem', 'sobre', 'entre', 'depois', 'mesmo',
    'quando', 'muito', 'nos', 'ele', 'ela', 'pelo', 'pela', 'ter',
    'seus', 'suas', 'há', 'era', 'ainda', 'também', 'só', 'será',
    'nem', 'vai', 'vem', 'bem', 'agora', 'aqui', 'lá', 'onde',
    'então', 'cada', 'toda', 'novo', 'nova', 'novos', 'novas'
  ]);

  sentences.forEach(s => {
    s.toLowerCase().split(/\s+/).forEach(word => {
      const clean = word.replace(/[^a-záàâãéèêíïóôõúüç-]/gi, '');
      if (clean.length > 3 && !stopwords.has(clean)) {
        wordCount[clean] = (wordCount[clean] || 0) + 1;
      }
    });
  });

  return Object.entries(wordCount)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 30)
    .map(([word, count]) => ({ word, count }));
}

function buildProfile(n = 5, force = false) {
  // Skip if profile is recent
  if (!force && fs.existsSync(PROFILE_FILE)) {
    const profile = JSON.parse(fs.readFileSync(PROFILE_FILE, 'utf8'));
    const age = Date.now() - new Date(profile.generatedAt).getTime();
    const daysSince = age / (1000 * 60 * 60 * 24);

    if (daysSince < 14) {
      console.log(`Voice profile is ${Math.round(daysSince)} days old (< 14). Use --force to recalculate.`);
      return profile;
    }
  }

  if (!fs.existsSync(NEWSLETTERS_DIR)) {
    console.error(`No newsletters directory found at: ${NEWSLETTERS_DIR}`);
    console.error('Run /newsletter-toolkit:digest first to generate some newsletters.');
    process.exit(1);
  }

  const files = fs.readdirSync(NEWSLETTERS_DIR)
    .filter(f => f.endsWith('.md'))
    .sort()
    .reverse()
    .slice(0, n);

  if (files.length === 0) {
    console.error('No newsletter files found. Generate newsletters first with /newsletter-toolkit:digest');
    process.exit(1);
  }

  console.log(`Analyzing ${files.length} newsletters...`);

  const texts = files.map(f => {
    console.log(`  → ${f}`);
    return readNewsletter(path.join(NEWSLETTERS_DIR, f));
  });

  const allSentences = texts.flatMap(extractSentences);

  const profile = {
    generatedAt: new Date().toISOString(),
    basedOn: files,
    sampleSize: {
      newsletters: files.length,
      sentences: allSentences.length,
      totalWords: allSentences.reduce((sum, s) => sum + s.split(/\s+/).length, 0)
    },
    rhythm: analyzeSentenceRhythm(allSentences),
    openings: extractOpeningPatterns(texts),
    transitions: [...new Set(texts.flatMap(extractTransitionPatterns))],
    editorialPhrases: extractEditorialPhrases(texts.join('\n')),
    vocabulary: {
      frequent: extractFrequentWords(allSentences),
      ...extractWordsAvoided(allSentences)
    },
    structuralPatterns: {
      usesBulletPointsIn: ['O que rolou essa semana', 'Drops'],
      headingStyle: 'sentence-case',
      separatorBetweenSections: '---',
      boldUsage: 'feature and product names only',
      emojiUsage: 'none in body'
    }
  };

  fs.mkdirSync(path.dirname(PROFILE_FILE), { recursive: true });
  fs.writeFileSync(PROFILE_FILE, JSON.stringify(profile, null, 2), 'utf8');

  console.log(`\nVoice profile saved: ${PROFILE_FILE}`);
  console.log(`Based on ${profile.sampleSize.newsletters} newsletters, ${profile.sampleSize.sentences} sentences`);

  return profile;
}

// CLI
const args = process.argv.slice(2);
const force = args.includes('--force');
const n = parseInt(args.find(a => a.match(/^\d+$/))) || 5;
buildProfile(n, force);
